  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: LionEvent
  m_EditorClassIdentifier: 
  eventTitle: Lion?
  eventDescription: Loud scratching sounds coming from inside the wall.
  eventImage: {fileID: 21300000, guid: 2d00e1996a91845458e63146fe45e936, type: 3}
  choices:
  - choiceText: Bang on the wall to scare whatever is making the sound.
    stressChange: 10
    trustChange: -10
    positiveOutcome: Scratching stops immediately.
    negativeOutcome: Something bigger starts scratching back louder.
    positiveChance: 0.4
  - choiceText: Cover your ears with the pillow and try to ignore it.
    stressChange: 0
    trustChange: 5
    positiveOutcome: You fall asleep and the sound eventually stops.
    negativeOutcome: "The sound gets inside your head and you can\u2019t relax."
    positiveChance: 0.7
  - choiceText: Throw your pants outside the door
    stressChange: 10
    trustChange: -10
    positiveOutcome: Guards comes to check you.
    negativeOutcome: You get soaked and catch a bad cold.
    positiveChance: 0.5
