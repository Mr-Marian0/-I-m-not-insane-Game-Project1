  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: Doctor1Event
  m_EditorClassIdentifier: 
  eventTitle: Doctor's visit
  eventDescription: "A doctor enters your cell with a clipboard and says, \u201CI
    need to ask you a few simple questions to check how you\u2019re doing."
  eventImage: {fileID: 21300000, guid: 8840acb35e4c0214e8be068a3173f841, type: 3}
  choices:
  - choiceText: Give short or strange answers.
    stressChange: 5
    trustChange: -15
    positiveOutcome: Doctor leaves quickly.
    negativeOutcome: He writes bad notes and loses trust in you.
    positiveChance: 0.7
  - choiceText: Answer all questions calmly and clearly.
    stressChange: -10
    trustChange: 15
    positiveOutcome: Doctor seems pleased and writes good notes.
    negativeOutcome: The questions make you feel exposed and anxious.
    positiveChance: 0.6
  - choiceText: "Answer but ask the doctor why he\u2019s asking."
    stressChange: -10
    trustChange: 5
    positiveOutcome: Doctor explains and spends more time with you.
    negativeOutcome: "He thinks you\u2019re being difficult and leaves early."
    positiveChance: 0.4
