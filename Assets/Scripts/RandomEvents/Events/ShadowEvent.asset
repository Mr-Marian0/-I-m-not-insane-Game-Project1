  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: ShadowEvent
  m_EditorClassIdentifier: 
  eventTitle: Meal Time
  eventDescription: Hospital meal tray arrived but food smelled rotten.
  eventImage: {fileID: 0}
  choices:
  - choiceText: Refuse the meal and ask for a new one.
    stressChange: -10
    trustChange: -5
    positiveOutcome: Nurse brings fresh food and apologizes.
    negativeOutcome: "Kitchen is closed because of the storm \u2013 no food at all."
    positiveChance: 0.5
  - choiceText: Throw the tray away and go back to sleep.
    stressChange: 10
    trustChange: -20
    positiveOutcome: You avoid food poisoning completely.
    negativeOutcome: You become very hungry and dizzy by morning.
    positiveChance: 0.5
  - choiceText: Eat only the safe parts (bread and water).
    stressChange: -5
    trustChange: 10
    positiveOutcome: You stay full enough and avoid sickness.
    negativeOutcome: "You\u2019re still hungry and feel weak later."
    positiveChance: 0.5
