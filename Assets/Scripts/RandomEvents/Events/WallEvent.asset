MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: WallEvent
  m_EditorClassIdentifier: 
  eventTitle: Something on the Wall
  eventDescription: While running your hand along the stone wall, you feel something
    metal stuck in a crack.
  eventImage: {fileID: 21300000, guid: 31640e1e2e7ad164ead4deeadc18e22e, type: 3}
  choices:
  - choiceText: Dig it out carefully.
    stressChange: -15
    trustChange: -5
    positiveOutcome: You get a small metal spoon.
    negativeOutcome: You cut your finger on the sharp edge.
    positiveChance: 0.4
  - choiceText: Leave it in the wall.
    stressChange: -5
    trustChange: 0
    positiveOutcome: Nothing bad happens.
    negativeOutcome: You keep thinking about it and feel restless.
    positiveChance: 0.4
  - choiceText: Bang on the door and tell the guard.
    stressChange: 5
    trustChange: -10
    positiveOutcome: Guard removes it.
    negativeOutcome: Guard ignores you.
    positiveChance: 0.6
