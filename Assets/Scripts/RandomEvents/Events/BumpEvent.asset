  m_Name: BumpEvent
  m_EditorClassIdentifier: 
  eventTitle: Something on the Window
  eventDescription: While touching the stone wall, you feel a strange bump.
  eventImage: {fileID: 21300000, guid: fd2db42854c493e4497d66949eb30aa8, type: 3}
  choices:
  - choiceText: Scratch the bump with your nail.
    stressChange: -5
    trustChange: 5
    positiveOutcome: A small nail falls out.
    negativeOutcome: Your nail breaks.
    positiveChance: 0.3
  - choiceText: Ignore the bump.
    stressChange: 0
    trustChange: 5
    positiveOutcome: Nothing bad happens.
    negativeOutcome: You feel uneasy about it.
    positiveChance: 0.7
  - choiceText: Hit the bump with your fist.
    stressChange: 10
    trustChange: 10
    positiveOutcome: The bump breaks off.
    negativeOutcome: Your hand hurts.
    positiveChance: 0.2
