  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: HandsEvent
  m_EditorClassIdentifier: 
  eventTitle: Shaky little hands
  eventDescription: You notice your hands are shaking uncontrollably.
  eventImage: {fileID: 21300000, guid: fbd3fbcbcea37af45982b66a173c4873, type: 3}
  choices:
  - choiceText: Hold your hands together tightly.
    stressChange: -5
    trustChange: 0
    positiveOutcome: The shaking slows down.
    negativeOutcome: Your arms become tired.
    positiveChance: 0.5
  - choiceText: Sit on them to stop the movement.
    stressChange: 5
    trustChange: 0
    positiveOutcome: They stop shaking for a while.
    negativeOutcome: You feel numb and strange.
    positiveChance: 0.3
  - choiceText: Ignore it and do nothing.
    stressChange: -5
    trustChange: 5
    positiveOutcome: It eventually stops by itself.
    negativeOutcome: The shaking spreads to your legs.
    positiveChance: 0.5
