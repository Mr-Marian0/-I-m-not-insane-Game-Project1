  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: ShoutEvent
  m_EditorClassIdentifier: 
  eventTitle: Aaahhhh!!..
  eventDescription: You suddenly have a strong urge to scream as loud as you can.
  eventImage: {fileID: 21300000, guid: d1a079e2358159847a463bc9145880cc, type: 3}
  choices:
  - choiceText: Let out a short scream.
    stressChange: -15
    trustChange: -15
    positiveOutcome: You feel some relief.
    negativeOutcome: Your throat hurts.
    positiveChance: 0.4
  - choiceText: Hit the bed instead to release energy.
    stressChange: -10
    trustChange: -5
    positiveOutcome: The urge disappears.
    negativeOutcome: Your hands hurt from hitting.
    positiveChance: 0.5
  - choiceText: Hold it in and clench your teeth.
    stressChange: -5
    trustChange: 0
    positiveOutcome: You stay quiet and in control.
    negativeOutcome: The urge gets stronger and stressful.
    positiveChance: 0.4
