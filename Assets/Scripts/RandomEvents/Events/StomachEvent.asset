  m_Name: StomachEvent
  m_EditorClassIdentifier: 
  eventTitle: Stomach Pain
  eventDescription: You suddenly feel a sharp pain in your stomach.
  eventImage: {fileID: 21300000, guid: d5ec523c57e8dbb43b5680eb9682ffcf, type: 3}
  choices:
  - choiceText: Bang on the door asking for medicine.
    stressChange: -5
    trustChange: -5
    positiveOutcome: Guard gives you a pill.
    negativeOutcome: No one answers.
    positiveChance: 0.5
  - choiceText: Walk around the cell to stretch.
    stressChange: -5
    trustChange: 0
    positiveOutcome: The pain goes away.
    negativeOutcome: The pain becomes worse.
    positiveChance: 0.4
  - choiceText: Lie down and rest.
    stressChange: -10
    trustChange: 0
    positiveOutcome: The pain slowly fades.
    negativeOutcome: The pain stays and you feel weak.
    positiveChance: 0.5
