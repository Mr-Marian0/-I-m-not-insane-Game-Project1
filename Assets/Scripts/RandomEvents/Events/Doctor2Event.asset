  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: Doctor2Event
  m_EditorClassIdentifier: 
  eventTitle: Docto's visit
  eventDescription: "The doctor asks: \u201CDo you know what day it is today and
    where you are?\u201D"
  eventImage: {fileID: 21300000, guid: 03c298c512c8ca542a1866faf58e7230, type: 3}
  choices:
  - choiceText: Answer correctly and confidently.
    stressChange: -10
    trustChange: 15
    positiveOutcome: Doctor nods and shows slight trust.
    negativeOutcome: You feel like a test subject.
    positiveChance: 0.6
  - choiceText: "Say you\u2019re not sure."
    stressChange: -5
    trustChange: -5
    positiveOutcome: Doctor explains the date and location patiently.
    negativeOutcome: He looks concerned and writes a note.
    positiveChance: 0.5
  - choiceText: Refuse to answer.
    stressChange: 5
    trustChange: -10
    positiveOutcome: "Doctor doesn\u2019t push you."
    negativeOutcome: He marks you as uncooperative.
    positiveChance: 0.8
