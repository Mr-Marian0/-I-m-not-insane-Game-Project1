  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: PushUpEvent
  m_EditorClassIdentifier: 
  eventTitle: I need to do Push ups
  eventDescription: You feel bored and decide to do push-ups.
  eventImage: {fileID: 21300000, guid: 6c6d4413124b19b48a04f60ebf226e4e, type: 3}
  choices:
  - choiceText: Do as many push-ups as you can.
    stressChange: -5
    trustChange: 10
    positiveOutcome: You feel stronger and more awake.
    negativeOutcome: Your arms hurt and you feel exhausted.
    positiveChance: 0.5
  - choiceText: Do only a few push-ups slowly.
    stressChange: -10
    trustChange: 5
    positiveOutcome: You feel a little better without strain.
    negativeOutcome: You still feel bored afterward.
    positiveChance: 0.5
  - choiceText: Stop and stay on the bed instead.
    stressChange: -15
    trustChange: 5
    positiveOutcome: You save your energy.
    negativeOutcome: Boredom becomes much stronger.
    positiveChance: 0.4
