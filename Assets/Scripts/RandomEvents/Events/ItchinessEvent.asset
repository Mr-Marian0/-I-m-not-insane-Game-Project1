  eventTitle: inthy everywhere
  eventDescription: You feel extremely itchy all over your body.
  eventImage: {fileID: 21300000, guid: e80005467c3d8cf498adae5dd46f4fe0, type: 3}
  choices:
  - choiceText: Do nothing and wait.
    stressChange: 15
    trustChange: 5
    positiveOutcome: The itch slowly fades.
    negativeOutcome: It becomes unbearable.
