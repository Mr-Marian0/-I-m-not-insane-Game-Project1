  eventTitle: Stalker
  eventDescription: A strong feeling of being watched comes over you.
  eventImage: {fileID: 21300000, guid: f704eda2af76a4345810a4c4f58794bc, type: 3}
  choices:
  - choiceText: "Shout \u201CStop watching me!\u201D"
    stressChange: 10
    trustChange: -10
    positiveOutcome: Saying it out loud helps you feel better.
    negativeOutcome: You feel embarrassed afterward.
    positiveChance: 0.3
  - choiceText: Cover yourself completely with the blanket.
    stressChange: -10
    trustChange: 0
    positiveOutcome: You feel slightly safer.
    negativeOutcome: The feeling becomes stronger.
    positiveChance: 0.5
  - choiceText: Look around every corner of the cell.
    stressChange: -5
    trustChange: -10
    positiveOutcome: The feeling slowly goes away.
    negativeOutcome: You feel even more paranoid.
    positiveChance: 0.3
