  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: GuardEvent
  m_EditorClassIdentifier: 
  eventTitle: Something on the Window
  eventDescription: "A guard tells you: \u201CIf you keep your cell clean and stay
    quiet, you might get better privileges.\u201D"
  eventImage: {fileID: 21300000, guid: 6a84faad88596d1448082a7e6c787b45, type: 3}
  choices:
  - choiceText: Ignore what he said.
    stressChange: 5
    trustChange: -10
    positiveOutcome: You feel safe and eventually fall asleep.
    negativeOutcome: Your imagination makes it worse and you stay awake all night.
    positiveChance: 0.5
  - choiceText: Say you will try your best.
    stressChange: -5
    trustChange: 10
    positiveOutcome: Guard gives you small praise.
    negativeOutcome: "He doesn\u2019t believe you fully."
    positiveChance: 0.5
  - choiceText: Clean your cell immediately.
    stressChange: -5
    trustChange: 15
    positiveOutcome: Guard notices and reports good behavior.
    negativeOutcome: You feel humiliated.
    positiveChance: 0.8
