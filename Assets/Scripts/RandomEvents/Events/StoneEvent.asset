  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: StoneEvent
  m_EditorClassIdentifier: 
  eventTitle: Stone on the wall
  eventDescription: You notice a small loose stone in the wall near the floor.
  eventImage: {fileID: 21300000, guid: 431b1ab57b14d7c4da457cead96897d2, type: 3}
  choices:
  - choiceText: Push it back in place.
    stressChange: -10
    trustChange: 0
    positiveOutcome: The wall looks normal again.
    negativeOutcome: The stone falls out again later.
    positiveChance: 0.4
  - choiceText: Try to pull the stone out.
    stressChange: -10
    trustChange: 0
    positiveOutcome: You remove it and feel satisfied.
    negativeOutcome: Dust falls into your eyes.
    positiveChance: 0.5
  - choiceText: Ignore the loose stone.
    stressChange: -5
    trustChange: 0
    positiveOutcome: Nothing happens.
    negativeOutcome: You keep staring at it.
    positiveChance: 0.4
