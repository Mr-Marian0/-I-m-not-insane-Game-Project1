  eventTitle: Food or not anymore
  eventDescription: You find an old piece of bread hidden under your bed.
  eventImage: {fileID: 21300000, guid: da6d0a9f09d8f6b47bd93451fb17506f, type: 3}
  choices:
  - choiceText: Throw it away.
    stressChange: -10
    trustChange: -5
    positiveOutcome: Your cell feels cleaner.
    negativeOutcome: You feel hungry later.
    positiveChance: 0.5
  - choiceText: Eat the bread.
    stressChange: -5
    trustChange: -5
    positiveOutcome: Your hunger decreases.
    negativeOutcome: It tastes bad and your stomach feels heavy.
    positiveChance: 0.3
  - choiceText: Save it for later.
    stressChange: -10
    trustChange: 5
    positiveOutcome: You feel prepared.
    negativeOutcome: You keep worrying it will go bad.
    positiveChance: 0.4
