  m_Name: AirEvent
  m_EditorClassIdentifier: 
  eventTitle: Air feels annoying
  eventDescription: The air in the cell starts feeling very stuffy and hard to breathe.
  eventImage: {fileID: 21300000, guid: 7d75272dfa384ca47a1b5f883b4a6bbd, type: 3}
  choices:
  - choiceText: Bang on the door for fresh air.
    stressChange: -5
    trustChange: -10
    positiveOutcome: Guard opens the door briefly.
    negativeOutcome: No one comes.
    positiveChance: 0.5
  - choiceText: Stay on the bed.
    stressChange: -10
    trustChange: -5
    positiveOutcome: Nothing changes much.
    negativeOutcome: You feel more tired and dizzy.
    positiveChance: 0.5
  - choiceText: Lie on the floor where air is cooler.
    stressChange: -10
    trustChange: 0
    positiveOutcome: Breathing feels easier.
    negativeOutcome: The floor is cold and dirty.
    positiveChance: 0.4
