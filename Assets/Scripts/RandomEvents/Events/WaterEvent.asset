  m_Name: WaterEvent
  m_EditorClassIdentifier: 
  eventTitle: Im so Thirsty
  eventDescription: Your mouth feels extremely dry and your tongue feels heavy.
  eventImage: {fileID: 21300000, guid: 2460fda8012938e4b9182eb97f2094a9, type: 3}
  choices:
  - choiceText: Drink all the water left in your cup.
    stressChange: -10
    trustChange: 5
    positiveOutcome: Your mouth feels much better.
    negativeOutcome: You now have no water left.
    positiveChance: 0.6
  - choiceText: Try to produce saliva by moving your tongue.
    stressChange: -5
    trustChange: 0
    positiveOutcome: It helps a little.
    negativeOutcome: It makes you feel nauseous.
    positiveChance: 0.3
  - choiceText: Call for more water.
    stressChange: 5
    trustChange: -5
    positiveOutcome: Guard refills your cup.
    negativeOutcome: No one answers.
    positiveChance: 0.6
