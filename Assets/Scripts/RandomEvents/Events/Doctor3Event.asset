  eventTitle: Doctor's visit
  eventDescription: "The doctor asks: \u201CDo you hear voices that other people
    don\u2019t hear?\u201D"
  eventImage: {fileID: 21300000, guid: b607bc48b52360145822e075f9d1d86b, type: 3}
  choices:
  - choiceText: "Say \u201CNo\u201D even if it\u2019s not true."
    stressChange: -5
    trustChange: 15
    positiveOutcome: Doctor looks satisfied.
    negativeOutcome: You feel more stressed inside.
    positiveChance: 0.7
