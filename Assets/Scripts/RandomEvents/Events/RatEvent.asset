  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: RatEvent
  m_EditorClassIdentifier: 
  eventTitle: Big Rat
  eventDescription: A big rat runs across the floor and hides under your bed.
  eventImage: {fileID: 21300000, guid: dcf23e35839f90042850ab2e9c04c678, type: 3}
  choices:
  - choiceText: Bang on the door for a guard.
    stressChange: 10
    trustChange: -10
    positiveOutcome: Guard removes the rat.
    negativeOutcome: Guard laughs at you and leaves.
    positiveChance: 0.4
  - choiceText: Lift your legs and stay on the bed.
    stressChange: -10
    trustChange: 5
    positiveOutcome: The rat eventually leaves.
    negativeOutcome: You hear more rats moving under the bed.
    positiveChance: 0.5
  - choiceText: Try to chase and kill the rat.
    stressChange: 10
    trustChange: -10
    positiveOutcome: You kill it with your shoe.
    negativeOutcome: You trip and hit your head on the stone wall.
    positiveChance: 0.5
