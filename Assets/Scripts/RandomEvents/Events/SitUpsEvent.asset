  m_Name: SitUpsEvent
  m_EditorClassIdentifier: 
  eventTitle: Stay fit
  eventDescription: You feel an urge to do sit-ups.
  eventImage: {fileID: 21300000, guid: db9c1632890baaa48815a7094f2abde3, type: 3}
  choices:
  - choiceText: Ignore the urge and stay still.
    stressChange: -5
    trustChange: 5
    positiveOutcome: You rest.
    negativeOutcome: You feel restless and irritated.
    positiveChance: 0.4
  - choiceText: Do many sit-ups.
    stressChange: -10
    trustChange: 5
    positiveOutcome: You feel energetic and focused.
    negativeOutcome: Your stomach muscles hurt a lot.
    positiveChance: 0.4
  - choiceText: Do a few sit-ups gently.
    stressChange: -15
    trustChange: 5
    positiveOutcome: You feel slightly better.
    negativeOutcome: The urge to move remains.
    positiveChance: 0.6
