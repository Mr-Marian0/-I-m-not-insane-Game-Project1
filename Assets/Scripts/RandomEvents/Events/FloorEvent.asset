  eventTitle: Wet Floor
  eventDescription: The stone floor feels unusually cold and wet under your feet.
  eventImage: {fileID: 21300000, guid: 64c0475da3e0f9b4eaed0927e3291e5f, type: 3}
  choices:
  - choiceText: Check under the bed.
    stressChange: -5
    trustChange: 5
    positiveOutcome: Just a small leak.
    negativeOutcome: You saw a black oily leak.
    positiveChance: 0.5
  - choiceText: Stay on the bed and ignore it.
    stressChange: -10
    trustChange: 0
    positiveOutcome: Nothing bad happens.
    negativeOutcome: The wet area keeps growing.
    positiveChance: 0.5
  - choiceText: Call the guard.
    stressChange: -10
    trustChange: 5
    positiveOutcome: Guard mops the floor.
    negativeOutcome: "Guard says it\u2019s normal and walks away."
