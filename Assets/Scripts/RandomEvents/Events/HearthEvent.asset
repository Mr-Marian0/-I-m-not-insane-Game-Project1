  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: HearthEvent
  m_EditorClassIdentifier: 
  eventTitle: Inside beat
  eventDescription: You start hearing your own heartbeat very loudly in your ears.
  eventImage: {fileID: 21300000, guid: bc73083eafc304b4085275ea83052881, type: 3}
  choices:
  - choiceText: Stand up and walk around the cell.
    stressChange: -10
    trustChange: 0
    positiveOutcome: The heartbeat sound fades.
    negativeOutcome: It gets even louder.
    positiveChance: 0.4
  - choiceText: Breathe slowly and deeply.
    stressChange: -15
    trustChange: 0
    positiveOutcome: The loud heartbeat calms down.
    negativeOutcome: It makes you feel dizzy.
    positiveChance: 0.6
  - choiceText: Press your hands over your ears.
    stressChange: -5
    trustChange: 0
    positiveOutcome: The sound becomes quieter.
    negativeOutcome: You start hearing your breathing instead.
    positiveChance: 0.3
