  m_Name: HeadEvent
  m_EditorClassIdentifier: 
  eventTitle: My Head hurts!
  eventDescription: Your head starts hurting badly.
  eventImage: {fileID: 21300000, guid: e98c10c294242704bb74fa0f29110987, type: 3}
  choices:
  - choiceText: Press your hands on your forehead
    stressChange: -5
    trustChange: 0
    positiveOutcome: The headache becomes lighter.
    negativeOutcome: The pain moves to your eyes.
    positiveChance: 0.6
  - choiceText: Lie down on the bed quietly.
    stressChange: -10
    trustChange: 5
    positiveOutcome: The headache slowly reduces.
    negativeOutcome: You feel more anxious.
    positiveChance: 0.6
  - choiceText: Shout for the nurse.
    stressChange: -10
    trustChange: -10
    positiveOutcome: Nurse gives you pain relief.
    negativeOutcome: No one comes.
    positiveChance: 0.5
