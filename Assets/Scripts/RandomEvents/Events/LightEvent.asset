--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: LightEvent
  m_EditorClassIdentifier: 
  eventTitle: Lights On and Off
  eventDescription: The overhead light starts flickering rapidly and makes a loud
    buzzing sound.
  eventImage: {fileID: 21300000, guid: 6818f7db76d937d4294a5b95f6fb7058, type: 3}
  choices:
  - choiceText: Hit the light to try and fix it.
    stressChange: -10
    trustChange: -5
    positiveOutcome: The light stops flickering and stays on.
    negativeOutcome: The light explodes and cuts your face badly.
    positiveChance: 0.3
  - choiceText: Ignore it and stay on the bed.
    stressChange: -10
    trustChange: 5
    positiveOutcome: It eventually stops by itself.
    negativeOutcome: It goes completely dark and you hear something moving in the
      cell.
    positiveChance: 0.5
  - choiceText: Bang on the metal door and shout for help.
    stressChange: -5
    trustChange: -10
    positiveOutcome: A guard comes and replaces the light.
    negativeOutcome: No one answers and the flickering gets worse.
    positiveChance: 0.5
