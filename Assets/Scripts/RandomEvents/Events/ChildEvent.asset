--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: ChildEvent
  m_EditorClassIdentifier: 
  eventTitle: Child Laughing
  eventDescription: You hear a child laughing loudly in the corridor right outside
    your door.
  eventImage: {fileID: 21300000, guid: 08e394938ae1022489265bea71a8599a, type: 3}
  choices:
  - choiceText: Call out to the child.
    stressChange: -5
    trustChange: -10
    positiveOutcome: The laughing stops and you feel a bit of relief.
    negativeOutcome: "The child\u2019s voice answers from inside your cell, whispering"
    positiveChance: 0.5
  - choiceText: Cover your ears and try to ignore it.
    stressChange: 5
    trustChange: 5
    positiveOutcome: The laughing slowly fades away.
    negativeOutcome: The laughter turns into many voices whispering horrible things
      about you.
    positiveChance: 0.5
  - choiceText: Bang on the door and scream for the guard.
    stressChange: 10
    trustChange: -10
    positiveOutcome: A guard opens the door and the sound disappears.
    negativeOutcome: "The guard says there is no child and stares at you suspiciously,
      like you\u2019re crazy."
    positiveChance: 0.6
