  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: StormEvent
  m_EditorClassIdentifier: 
  eventTitle: Strong Storm
  eventDescription: Strong storm with thunders, winds and leaks bothering you.
  eventImage: {fileID: 21300000, guid: 94895a846a775414db55e7e7943589ec, type: 3}
  choices:
  - choiceText: Stuff towels and blankets into the leaks to stop the water.
    stressChange: -10
    trustChange: 5
    positiveOutcome: Leaks stop, you stay dry and feel proud of yourself.
    negativeOutcome: You slip on wet floor and hurt your back.
    positiveChance: 0.4
  - choiceText: Shout loudly for a nurse to come help.
    stressChange: 10
    trustChange: 0
    positiveOutcome: A nurse arrives quickly and moves you to a dry bed.
    negativeOutcome: No one hears you because of the thunder; you feel more scared
      and
    positiveChance: 0.5
  - choiceText: Ignore everything and try to sleep anyway.
    stressChange: 10
    trustChange: 0
    positiveOutcome: You manage to rest a little and save energy.
    negativeOutcome: You get soaked and catch a bad cold.
    positiveChance: 0.3
