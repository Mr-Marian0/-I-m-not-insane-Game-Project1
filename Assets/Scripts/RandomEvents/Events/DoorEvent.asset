  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: DoorEvent
  m_EditorClassIdentifier: 
  eventTitle: Behind the Door
  eventDescription: The metal door suddenly starts shaking violently as if someone
    is kicking it from outside.
  eventImage: {fileID: 21300000, guid: c5a8c718550adb54fbb1a66598b18594, type: 3}
  choices:
  - choiceText: Go to the door and look through the small gap.
    stressChange: -5
    trustChange: 5
    positiveOutcome: You see a guard walking away.
    negativeOutcome: A hand reaches in and grabs your throat.
    positiveChance: 0.5
  - choiceText: "Shout \u201CWho is there?!\u201D"
    stressChange: 5
    trustChange: -5
    positiveOutcome: Nurse checks outside and reassures you.
    negativeOutcome: "Nurse says you\u2019re \u201Cseeing things\u201D and you feel
      crazy."
    positiveChance: 0.4
  - choiceText: Stay silent on your bed.
    stressChange: -10
    trustChange: 5
    positiveOutcome: The shaking stops after a while.
    negativeOutcome: The door lock starts making strange clicking sounds.
    positiveChance: 0.5
