  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: Box
  m_EditorClassIdentifier: 
  eventTitle: Something on the Window
  eventDescription: Moving shadows outside your window during the storm.
  eventImage: {fileID: 0}
  choices:
  - choiceText: Close the curtain tightly and hide under the blanket.
    stressChange: -5
    trustChange: 5
    positiveOutcome: You feel safe and eventually fall asleep.
    negativeOutcome: Your imagination makes it worse and you stay awake all night.
    positiveChance: 0.5
  - choiceText: Call the nurse and tell them about the shadows.
    stressChange: 10
    trustChange: -10
    positiveOutcome: Nurse checks outside and reassures you.
    negativeOutcome: "Nurse says you\u2019re \u201Cseeing things\u201D and you feel
      crazy."
    positiveChance: 0.4
  - choiceText: Open the curtain wider to see what it is.
    stressChange: -10
    trustChange: 0
    positiveOutcome: "It\u2019s only tree branches \u2013 you laugh and feel silly."
    negativeOutcome: You see a scary figure and scream in terror.
    positiveChance: 0.6
