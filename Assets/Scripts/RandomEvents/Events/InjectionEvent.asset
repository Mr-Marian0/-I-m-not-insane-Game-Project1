  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: InjectionEvent
  m_EditorClassIdentifier: 
  eventTitle: Injection!
  eventDescription: Male nurse says you need a painful injection right now.
  eventImage: {fileID: 0}
  choices:
  - choiceText: "Tell him you\u2019re scared and ask him to wait 5 minutes."
    stressChange: -5
    trustChange: 5
    positiveOutcome: He calms you down and explains everything first.
    negativeOutcome: "He says there\u2019s no time and forces the injection."
    positiveChance: 0.8
  - choiceText: Ask if there is another way (pill or cream).
    stressChange: 10
    trustChange: 10
    positiveOutcome: He agrees and gives you a painless option.
    negativeOutcome: He refuses and gets angry.
    positiveChance: 0.7
  - choiceText: Agree and let him give the injection.
    stressChange: 10
    trustChange: -10
    positiveOutcome: Medicine works and your pain disappears.
    negativeOutcome: Injection hurts a lot and leaves a big bruise.
    positiveChance: 0.5
