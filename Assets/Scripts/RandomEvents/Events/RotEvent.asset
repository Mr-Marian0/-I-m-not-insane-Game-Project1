  m_Script: {fileID: 11500000, guid: 270b6ff8ef28c054c8a9624f9dacedcb, type: 3}
  m_Name: RotEvent
  m_EditorClassIdentifier: 
  eventTitle: Rotting Meat
  eventDescription: A strong foul smell (like rotting meat) starts filling the cell.
  eventImage: {fileID: 21300000, guid: 98054d2a1a5c91a48802e7d02620479d, type: 3}
  choices:
  - choiceText: Cover your face with the blanket.
    stressChange: -5
    trustChange: 5
    positiveOutcome: The smell slowly fades.
    negativeOutcome: You feel sick and start vomiting.
    positiveChance: 0.5
  - choiceText: Bang on the door for fresh air.
    stressChange: -10
    trustChange: -10
    positiveOutcome: Guard opens a vent.
    negativeOutcome: The smell gets even stronger.
    positiveChance: 0.5
  - choiceText: Search the cell for the source of the smell.
    stressChange: -10
    trustChange: 5
    positiveOutcome: You find old rotten food under the bed.
    negativeOutcome: You find something much worse.
    positiveChance: 0.5
